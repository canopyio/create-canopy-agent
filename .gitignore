# Dependencies
node_modules/

# Build output (regenerated by `npm run build`; npm publish runs prepublishOnly which rebuilds)
dist/
*.tsbuildinfo

# npm pack output (from `npm pack` / `npm pack --dry-run` testing)
*.tgz

# Environment (no .env required at runtime — secrets come from interactive prompts —
# but ignore defensively in case anyone tests with API keys in env)
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
